SESSION_SECRET="change-this-to-a-random-32-character-string"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
ADMIN_EMAILS="feelmiss@gaehyeon.sen.es.kr"
ALADIN_TTB_KEY=""
DATA4LIBRARY_API_KEY=""
STDICT_API_KEY=""

# Firebase (웹 클라이언트) — 콘솔 > 프로젝트 설정 > 일반 > 내 앱 > SDK 구성
NEXT_PUBLIC_FIREBASE_API_KEY="AIzaSy..."
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project-id.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="123456789012"
NEXT_PUBLIC_FIREBASE_APP_ID="1:123456789012:web:abcdef123456"

# Firebase Admin (서버 API) — 프로젝트 설정 > 서비스 계정 > 새 비공개 키 JSON
# 클라이언트·Admin 키가 모두 있어야 Firestore·로그인이 활성화됩니다.
# private key 줄바꿈은 \n 로 넣기
FIREBASE_ADMIN_PROJECT_ID="your-project-id"
FIREBASE_ADMIN_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com"
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Google AI (Gemini) — 감상문 도우미 + 기억에 남는 장면 그림 검사
GEMINI_API_KEY="AIzaSy..."
GEMINI_MODEL="gemini-3.1-flash-lite"

# ── Firebase 설정 순서 (최초 1회) ─────────────────────────────────────
# 1) 콘솔: Authentication(Google·이메일/비밀번호), Firestore, Storage(Blaze) 활성화
# 2) .env.local 에 위 변수 입력
# 3) 연결 확인: npm run dev 후 /api/firebase/status 또는 npm run firebase:test-storage
# 4) 보안 규칙 배포: npx firebase login 후 npm run firebase:deploy-rules
#
# ── db.json → Firestore 동기화 (기존 데이터 이전, 필요 시) ─────────────
# npm run firebase:sync-users
# npm run firebase:sync-books
# npm run firebase:sync-sentences
# npm run firebase:sync-chat
# npm run firebase:sync-admin-data
# npm run firebase:sync-empathy
# npm run firebase:migrate-scenes
#
# PowerShell에서 npm 실행 오류 시: npm.cmd run ...

    {
      "id": "4323d0ef-4f12-4208-a708-0bfb725d3a77",
      "userId": "ff1a9f0a-02ff-45b1-9787-d892744ec309",
      "word": "알근달근-하다",
      "definition": "(형용사) 맛이 조금 매우면서 달짝지근하다.",
      "createdAt": "2026-06-22T06:30:17.985Z"

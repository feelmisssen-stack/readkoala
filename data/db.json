      "createdAt": "2026-06-29T05:13:08.853Z"
    },
    {
      "id": "00265caa-da6a-4f77-b8b9-b1eeafd742fd",
      "userId": "ff1a9f0a-02ff-45b1-9787-d892744ec309",
      "word": "보다",
